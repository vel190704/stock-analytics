APP_NAME="Stock Analytics API"
ENVIRONMENT=development
LOG_LEVEL=INFO

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=stock_prices
KAFKA_DLQ_TOPIC=stock_prices_dlq
KAFKA_CONSUMER_GROUP=stock-processor-group

DATABASE_URL=postgresql+asyncpg://stockuser:stockpass@postgres:5432/stockdb
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://redis:6379/0
ANALYTICS_CACHE_TTL=30

POLYGON_API_KEY=
NEWSAPI_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-1

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@stockanalytics.local

ALLOW_SIMULATED_DATA=false
TICKERS=["AAPL","MSFT","GOOGL","AMZN","TSLA","META","NVDA","JPM","V","NFLX"]
POLL_INTERVAL_SECONDS=1.0
