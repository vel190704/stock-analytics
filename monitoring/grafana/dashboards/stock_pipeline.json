          ],
          "displayMode": "list"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(messages_produced_total[1m])",
          "legendFormat": "Produced/s ({{ticker}})"
        }
      ],
      "title": "Messages Produced per Second",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(messages_consumed_total{status='success'}[1m])",
          "legendFormat": "Consumed/s ({{ticker}})"
        }
      ],
      "title": "Messages Consumed per Second",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
