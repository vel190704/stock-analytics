              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "active_websocket_connections",
          "legendFormat": "WebSocket connections"
        }
      ],
      "title": "Active WebSocket Connections",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 4,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(db_write_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 DB write latency"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(db_write_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 DB write latency"
        }
      ],
      "title": "DB Write Latency (p50/p99)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
